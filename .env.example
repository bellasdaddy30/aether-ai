# ============================================================
#  AETHER AI — Environment Configuration
#  Copy to .env and fill in your values
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d

# Database (SQLite path)
DB_PATH=./aether.db

# ---- AI / LLM -----------------------------------------------
# OpenRouter — free tier available, pay-as-you-go beyond
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models per tier (OpenRouter model strings)
MODEL_BASICS=mistralai/mistral-7b-instruct:free
MODEL_ELITE=nousresearch/hermes-3-llama-3.1-70b
MODEL_GODMODE=anthropic/claude-sonnet-4-5

# ---- Image Generation ----------------------------------------
# Replicate — pay-as-you-go, no monthly fee
# Sign up: https://replicate.com
REPLICATE_API_TOKEN=r8_REPLACE_ME

# Replicate model IDs
IMAGE_MODEL_BASICS=stability-ai/sdxl:39ed52f2319f9c04f59b2eb2292b3e5eb0d4bb5e2fbfbe29b2f8b97a05EB4D0
IMAGE_MODEL_ELITE=black-forest-labs/flux-schnell
IMAGE_MODEL_GODMODE=black-forest-labs/flux-1.1-pro

# ---- Text-to-Speech ------------------------------------------
# ElevenLabs — free tier: 10k chars/month
# Sign up: https://elevenlabs.io
ELEVENLABS_API_KEY=REPLACE_ME
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ---- Stripe --------------------------------------------------
# Sign up: https://stripe.com — no monthly fee, only transaction %
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_BASICS=price_REPLACE_ME
STRIPE_PRICE_ELITE=price_REPLACE_ME
STRIPE_PRICE_GODMODE=price_REPLACE_ME

# ---- App URL -------------------------------------------------
APP_URL=http://localhost:3000
